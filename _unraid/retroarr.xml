<?xml version="1.0"?>
<Container version="2">
  <Name>RetroArr</Name>
  <Repository>ghcr.io/riddix/retroarr:latest</Repository>
  <Registry>https://github.com/RiDDiX/RetroArr/pkgs/container/retroarr</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/RiDDiX/RetroArr/issues</Support>
  <Project>https://github.com/RiDDiX/RetroArr</Project>
  <Overview>
    RetroArr is a self-hosted game library manager and PVR, inspired by Radarr and Sonarr. It manages your game library across 55+ platforms, fetches metadata from IGDB/Steam/ScreenScraper, handles downloads via Prowlarr/Jackett, and supports Linux gaming integrations (Proton, Lutris, Steam Deck).
  </Overview>
  <Category>MediaApp:Video GameServers: Tools:</Category>
  <WebUI>http://[IP]:[PORT:2727]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/RiDDiX/RetroArr/main/_unraid/retroarr.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/RiDDiX/RetroArr/main/frontend/src/assets/app_logo.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText>Support RetroArr</DonateText>
  <DonateLink>https://github.com/RiDDiX/RetroArr</DonateLink>
  <Description>
    RetroArr is a self-hosted game library manager and PVR.
    Features:
    - Intelligent Library Scanning (55+ platforms)
    - Metadata from IGDB, Steam &amp; ScreenScraper
    - Prowlarr &amp; Jackett Integration
    - NZB &amp; Torrent Download Support
    - Linux Gaming: Proton, Lutris, Steam Deck exports
    - Plugin System for community extensions
  </Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>2727</HostPort>
        <ContainerPort>2727</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/RetroArr/config</HostDir>
      <ContainerDir>/app/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/games</HostDir>
      <ContainerDir>/media</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/downloads</HostDir>
      <ContainerDir>/downloads</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>1000</Value>
      <Name>PUID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>1000</Value>
      <Name>PGID</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Config Name="Web Port" Target="2727" Default="2727" Mode="tcp" Description="The port for the RetroArr Web UI." Type="Port" Display="always" Required="true" Mask="false">2727</Config>
  <Config Name="Appdata" Target="/app/config" Default="/mnt/user/appdata/RetroArr/config" Mode="rw" Description="Location for RetroArr configuration and database." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/RetroArr/config</Config>
  <Config Name="Games Library" Target="/media" Default="/mnt/user/games" Mode="rw" Description="Location of your game library." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/games</Config>
  <Config Name="Downloads" Target="/downloads" Default="/mnt/user/downloads" Mode="rw" Description="Downloads directory for completed files." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/downloads</Config>
  <Config Name="PUID" Target="PUID" Default="1000" Description="User ID for file permissions." Type="Variable" Display="advanced" Required="false" Mask="false">1000</Config>
  <Config Name="PGID" Target="PGID" Default="1000" Description="Group ID for file permissions." Type="Variable" Display="advanced" Required="false" Mask="false">1000</Config>
</Container>
